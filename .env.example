# --- Supabase (project: 5-Minutes-Forward, ref: nourqoxqgxaulfstdgwn) ---
# Public — safe to ship to the browser. Used for all read-only queries
# and for the three intentionally-public inserts (feedback, playback_event,
# share_event), which are allowed by RLS policies already in place.
NEXT_PUBLIC_SUPABASE_URL=https://nourqoxqgxaulfstdgwn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_anon_or_publishable_key

# SERVER-ONLY — never prefix with NEXT_PUBLIC_, never import into a
# client component. Bypasses RLS entirely. Used only by /app/api/admin/*
# route handlers to perform CMS writes (episodes, groupings, topics,
# site settings).
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

# --- Admin auth (Phase A: password + signed session cookie) ---
# A long random string used to sign the admin session cookie. Generate
# with e.g. `openssl rand -hex 32`. Rotating this invalidates all
# existing admin sessions.
ADMIN_SESSION_SECRET=replace_with_random_secret
# The password entered on /admin/login. For a single-admin MVP this is
# enough; move to Supabase Auth (see product spec §10 discussion) if
# multiple editor accounts are ever needed.
ADMIN_PASSWORD=replace_with_a_real_password

# --- Cloudflare R2 (S3-compatible API) ---
# Used only server-side, by /app/api/admin/audio-upload-url (issues a
# presigned PUT so the CMS can upload directly to R2) and
# /app/api/audio/[slug] (streams/redirects to the object). The client
# never sees these credentials or a raw R2 URL — see lib/audio.ts and
# product spec §9.
R2_ACCOUNT_ID=replace_with_cloudflare_account_id
R2_ACCESS_KEY_ID=replace_with_r2_access_key_id
R2_SECRET_ACCESS_KEY=replace_with_r2_secret_access_key
R2_BUCKET_NAME=replace_with_bucket_name
# Public hostname audio is served from once a CDN/custom domain sits in
# front of the bucket (e.g. audio.techmedng.com). Leave blank to fall
# back to presigned R2 URLs directly.
R2_PUBLIC_HOSTNAME=
